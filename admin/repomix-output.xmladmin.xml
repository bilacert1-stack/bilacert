    openGraph: {
      title: post.title,
      description: post.excerpt,
      url: `${siteUrl}/blog/${post.slug}`,
      type: "article",
      publishedTime: post.created_at,
      images: post.featured_image ? [{ url: post.featured_image }] : [],
    },
  };
}

