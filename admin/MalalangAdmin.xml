              <div className="border-t border-gray-100 pt-6">
                <label className="text-xs font-bold text-gray-400 uppercase tracking-widest block mb-2">Meta Description</label>
                <p className="text-sm text-gray-600 italic leading-relaxed">&quot;{blog.metaDescription}&quot;</p>
              </div>
              <div className="border-t border-gray-100 pt-6">
                <label className="text-xs font-bold text-gray-400 uppercase tracking-widest block mb-2">Keywords</label>
                <p className="text-sm text-gray-600 leading-relaxed">{blog.keywords}</p>
              </div>
              <div className="border-t border-gray-100 pt-6">
                <label className="text-xs font-bold text-gray-400 uppercase tracking-widest block mb-2">Internal Slug</label>
                <code className="text-xs bg-gray-100 px-2 py-1 rounded text-emerald-700 font-mono">{blog.slug}</code>
