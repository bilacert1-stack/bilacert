<file path="admin/components/PostValidator.tsx">
"use client";

import { useState } from "react";
import { blogPostSchema } from "@/lib/validation";
import type { BlogPost } from "@/lib/types";
import { updateBlogPostAction } from "@/lib/actions";
import { AlertCircle, CheckCircle, Save, Loader2, X, AlertTriangle } from "lucide-react";

interface PostValidatorProps {
  posts: BlogPost[];
  onUpdate: () => void;
}

interface AuditResult {
  post: BlogPost;
  errors: Record<string, string>;
  formData: Record<string, string>;
}

export default function PostValidator({ posts, onUpdate }: PostValidatorProps) {
  const [auditResults, setAuditResults] = useState<AuditResult[]>([]);
  const [isScanning, setIsScanning] = useState(false);
  const [savingField, setSavingField] = useState<{ postId: string; field: string } | null>(null);

  const scanPosts = () => {
    setIsScanning(true);
    const results: AuditResult[] = [];

    posts.forEach((post) => {
      const data = {
        title: post.title || "",
        slug: post.slug || "",
        htmlContent: post.htmlContent || "",
        excerpt: post.excerpt || "",
        metaTitle: post.metaTitle || "",
        metaDescription: post.metaDescription || "",
        publishedAt: post.publishedAt || "",
        tags: post.tags || [],
        imageUrl: post.imageUrl || "",
        reading_time_minutes: post.reading_time_minutes || 0,
        keywords: post.keywords || "",
        source: post.source || "malalang",
        status: post.status || "published",
        author: post.author || {
          id: "abram-ntsako",
          name: "AEN Nyathi",
          avatarUrl: "/assets/profile.jpg",
          imageUrl: "/assets/profile.jpg",
          bio: "Abram Ntsako is the founder of Malalang Pty Ltd, a web development studio dedicated to empowering local businesses in Phalaborwa. With a passion for clean code and user-centric design, he helps SMEs build a strong online presence without breaking the bank."
        },
      };

      const result = blogPostSchema.safeParse(data);
      if (!result.success) {
        const formattedErrors: Record<string, string> = {};
        result.error.issues.forEach((issue) => {
          const path = issue.path.join(".");
          formattedErrors[path] = issue.message;
        });
        results.push({
          post,
          errors: formattedErrors,
          formData: data as any,
        });
      }
    });

    setAuditResults(results);
    setIsScanning(false);
  };

  const handleFieldChange = (postId: string, field: string, value: string) => {
    setAuditResults((prev) =>
      prev.map((res) =>
        res.post.id === postId
          ? { ...res, formData: { ...res.formData, [field]: value } }
          : res
      )
    );
  };

  const handleUpdateField = async (postId: string, field: string) => {
    const result = auditResults.find((r) => r.post.id === postId);
    if (!result) return;

    setSavingField({ postId, field });
    try {
      const value = result.formData[field];
      const res = await updateBlogPostAction(postId, { [field]: value });
      
      if (res.success) {
        // Remove error for this field
        setAuditResults((prev) =>
          prev.map((r) => {
            if (r.post.id === postId) {
              const newErrors = { ...r.errors };
              delete newErrors[field];
              return { ...r, errors: newErrors };
            }
            return r;
          }).filter((r) => Object.keys(r.errors).length > 0)
        );
        onUpdate();
      } else {
        alert("Update failed: " + res.error);
      }
    } finally {
      setSavingField(null);
    }
  };

  return (
    <div className="mb-8">
      <div className="flex items-center justify-between mb-6">
        <button
          onClick={scanPosts}
          disabled={isScanning}
          className="inline-flex items-center gap-2 bg-amber-500 hover:bg-amber-600 text-white font-semibold py-2 px-4 rounded-lg text-sm transition-colors shadow-sm disabled:opacity-50"
        >
          {isScanning ? <Loader2 className="animate-spin" size={16} /> : <AlertTriangle size={16} />}
          Scan Posts for Errors
        </button>
        
        {auditResults.length > 0 && (
          <button 
            onClick={() => setAuditResults([])}
            className="text-gray-400 hover:text-gray-600 transition-colors"
          >
            <X size={20} />
          </button>
        )}
      </div>

      {auditResults.length > 0 && (
        <div className="space-y-6 animate-in fade-in slide-in-from-top-4 duration-300">
          <div className="bg-amber-50 border border-amber-200 rounded-lg p-4 flex items-center gap-3 text-amber-800">
            <AlertCircle size={20} />
            <p className="text-sm font-medium">
              Found {auditResults.length} posts with data integrity issues. Fix them below.
            </p>
          </div>

          <div className="grid grid-cols-1 gap-6">
            {auditResults.map((result) => (
              <div key={result.post.id} className="bg-white rounded-xl border-2 border-red-100 shadow-md overflow-hidden">
                <div className="bg-red-50 px-5 py-3 border-b border-red-100 flex items-center justify-between">
                  <h3 className="font-bold text-red-900">{result.post.title}</h3>
                  <span className="text-xs font-bold bg-red-200 text-red-800 px-2 py-0.5 rounded-full uppercase">
                    {Object.keys(result.errors).length} Issues
                  </span>
                </div>
                
                <div className="p-5 space-y-4">
                  {Object.entries(result.errors).map(([field, message]) => (
                    <div key={field} className="flex flex-col md:flex-row md:items-end gap-4 p-3 bg-gray-50 rounded-lg border border-gray-100">
                      <div className="flex-1">
                        <label className="block text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-1">
                          {field.replace(/([A-Z])/g, " $1").replace(/^./, (str) => str.toUpperCase())}
                          <span className="ml-2 text-red-500 normal-case font-medium italic">({message})</span>
                        </label>
                        
                        {field === "publishedAt" ? (
                          <input
                            type="date"
                            value={result.formData[field].split("T")[0]}
                            onChange={(e) => handleFieldChange(result.post.id, field, e.target.value)}
                            className="w-full bg-white border border-red-200 rounded-md px-3 py-1.5 text-sm focus:ring-2 focus:ring-emerald-500 focus:border-transparent outline-none transition-all"
                          />
                        ) : (
                          <input
                            type="text"
                            value={result.formData[field]}
                            onChange={(e) => handleFieldChange(result.post.id, field, e.target.value)}
                            className="w-full bg-white border border-red-200 rounded-md px-3 py-1.5 text-sm focus:ring-2 focus:ring-emerald-500 focus:border-transparent outline-none transition-all"
                          />
                        )}
                      </div>
                      
                      <button
                        onClick={() => handleUpdateField(result.post.id, field)}
                        disabled={savingField?.postId === result.post.id && savingField?.field === field}
                        className="inline-flex items-center gap-1.5 bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-bold py-2 px-4 rounded shadow-sm disabled:opacity-50 transition-colors h-9"
                      >
                        {savingField?.postId === result.post.id && savingField?.field === field ? (
                          <Loader2 className="animate-spin" size={14} />
                        ) : (
                          <Save size={14} />
                        )}
                        Update
                      </button>
                    </div>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
    </div>
  );
}
</file>

<file path="admin/lib/actions.ts">
"use server";

import { revalidatePath } from "next/cache";
import { createBlog, updateBlog, deleteBlog as dbDeleteBlog } from "./db";
import { blogPostSchema, type BlogPostInput } from "./validation";
import { blogSchema } from "@/app/blog/schema";

export async function updateBlogPostAction(id: string, data: any) {
  try {
    const updateData: any = { ...data };
    
    // Standardise author if name is provided (for scanner fixes)
    if (data.authorName) {
      updateData.author = {
        id: "abram-ntsako",
        name: "AEN Nyathi",
        avatarUrl: "/assets/profile.jpg",
        imageUrl: "/assets/profile.jpg",
        bio: "Abram Ntsako is the founder of Malalang Pty Ltd, a web development studio dedicated to empowering local businesses in Phalaborwa. With a passion for clean code and user-centric design, he helps SMEs build a strong online presence without breaking the bank."
      };
      delete updateData.authorName;
    }

    await updateBlog(id, updateData);

    revalidatePath("/blog");
    revalidatePath(`/blog/${id}`);
    revalidatePath("/admin/blog");
    return { success: true };
  } catch (error: any) {
    return { success: false, error: error.message };
  }
}

export async function upsertBlog(values: unknown) {
  const parsedValues = blogSchema.safeParse(values);

  if (!parsedValues.success) {
    return { error: parsedValues.error.message };
  }

  const { id, ...rest } = parsedValues.data;

  // Prepare the data matching the exact schema
  const blogData = {
    ...rest,
    tags: typeof rest.tags === 'string' 
      ? rest.tags.split(",").map(t => t.trim()).filter(Boolean) 
      : rest.tags,
    reading_time_minutes: Math.ceil(rest.reading_time_minutes),
    source: "malalang" as const,
    author: {
      id: "abram-ntsako",
      name: "AEN Nyathi",
      avatarUrl: "/assets/profile.jpg",
      imageUrl: "/assets/profile.jpg",
      bio: "Abram Ntsako is the founder of Malalang Pty Ltd, a web development studio dedicated to empowering local businesses in Phalaborwa. With a passion for clean code and user-centric design, he helps SMEs build a strong online presence without breaking the bank."
    }
  };

  try {
    if (id) {
      await updateBlog(id, blogData);
    } else {
      await createBlog(blogData as any);
    }

    revalidatePath("/blog");
    revalidatePath(`/blog/${rest.slug}`);
    revalidatePath("/admin/blog");

    return { error: null };
  } catch (error: any) {
    return { error: `Database error: ${error.message}` };
  }
}

export async function deleteBlogAction(blogId: string) {
  try {
    await dbDeleteBlog(blogId);
    revalidatePath("/blog");
    revalidatePath("/admin/blog");
    return { error: null };
  } catch (error: any) {
    return { error: `Database error: ${error.message}` };
  }
}
