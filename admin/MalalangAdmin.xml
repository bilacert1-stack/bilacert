import { useEffect, useTransition } from 'react';
import { Loader2, Save, X, Sparkles } from 'lucide-react';
import { useRouter } from 'next/navigation';
import Link from 'next/link';
import { Card, CardContent, CardHeader, CardTitle } from '@/components/ui/card';
import { blogSchema, BlogFormValues } from './schema';
import { upsertBlog } from '@/lib/actions';
import BlogEditor from './BlogEditor';
import PexelsImagePicker from '@/components/PexelsImagePicker';

interface BlogFormProps {
  blog?: BlogPost | null;
}

const slugify = (str: string) =>
  str
    .toLowerCase()
    .trim()
    .replace(/[^\w\s-]/g, '')
    .replace(/[\s_-]+/g, '-')
    .replace(/^-+|-+$/g, '');

export default function BlogForm({ blog }: BlogFormProps) {
  const router = useRouter();
  const [isPending, startTransition] = useTransition();

  const form = useForm<BlogFormValues>({
    resolver: zodResolver(blogSchema),
    defaultValues: {
      title: '',
      slug: '',
      tags: '',
      excerpt: '',
      htmlContent: '',
      imageUrl: '/logo.png',
      publishedAt: new Date().toISOString().split('T')[0],
      metaTitle: '',
      metaDescription: '',
      reading_time_minutes: 5,
      keywords: '',
      source: 'malalang',
      status: 'published',
      author: {
        id: "abram-ntsako",
        name: "AEN Nyathi",
        avatarUrl: "/assets/profile.jpg",
        imageUrl: "/assets/profile.jpg",
        bio: "Abram Ntsako is the founder of Malalang Pty Ltd, a web development studio dedicated to empowering local businesses in Phalaborwa. With a passion for clean code and user-centric design, he helps SMEs build a strong online presence without breaking the bank."
      }
    },
  });

  const { handleSubmit, reset, watch, setValue } = form;

  const title = watch('title');
  const imageUrl = watch('imageUrl');
  const tagsStr = watch('tags') || '';
  const isEditing = !!blog;

  useEffect(() => {
    if (!isEditing && title) {
      setValue('slug', slugify(title), { shouldValidate: true });
    }
  }, [title, setValue, isEditing]);

  useEffect(() => {
    if (blog) {
      reset({
        id: blog.id,
        title: blog.title || '',
        slug: blog.slug || '',
        tags: blog.tags?.join(', ') || '',
        excerpt: blog.excerpt || '',
        htmlContent: blog.htmlContent || '',
        imageUrl: blog.imageUrl || '/logo.png',
        publishedAt: blog.publishedAt ? new Date(blog.publishedAt).toISOString().split('T')[0] : new Date().toISOString().split('T')[0],
        metaTitle: blog.metaTitle || '',
        metaDescription: blog.metaDescription || '',
        reading_time_minutes: blog.reading_time_minutes || 5,
        keywords: blog.keywords || '',
        source: 'malalang',
        status: (blog.status as any) || 'published',
        author: blog.author || {
          id: "abram-ntsako",
          name: "AEN Nyathi",
          avatarUrl: "/assets/profile.jpg",
          imageUrl: "/assets/profile.jpg",
          bio: "Abram Ntsako is the founder of Malalang Pty Ltd, a web development studio dedicated to empowering local businesses in Phalaborwa. With a passion for clean code and user-centric design, he helps SMEs build a strong online presence without breaking the bank."
        }
      });
    }
  }, [blog, reset]);

  const generateSlug = () => {
    if (title) {
      setValue('slug', slugify(title), { shouldValidate: true });
    }
  };

  const onSubmit = (values: BlogFormValues) => {
    startTransition(async () => {
      const result = await upsertBlog(values);
      if (result.error) {
        alert(result.error);
      } else {
        router.push('/blog');
        router.refresh();
      }
    });
  };

  return (
    <Form {...form}>
      <form onSubmit={handleSubmit(onSubmit)} className="space-y-8 pb-20">
        <div className="grid grid-cols-1 gap-8 lg:grid-cols-3">
          <div className="space-y-6 lg:col-span-2">
            <Card className="border-gray-200 shadow-sm">
              <CardHeader className="border-b border-gray-100 bg-gray-50/50">
                <CardTitle className="text-gray-900 text-lg">Article Content</CardTitle>
              </CardHeader>
              <CardContent className="pt-6">
                <FormField
                  control={form.control}
                  name="htmlContent"
                  render={({ field }) => (
                    <FormItem>
                      <FormControl>
                        <BlogEditor
                          imageUrl={imageUrl}
                          value={field.value ?? ''}
                          onChange={field.onChange}
                          title={title}
                        />
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />
              </CardContent>
            </Card>

            <Card className="border-gray-200 shadow-sm">
              <CardHeader className="border-b border-gray-100 bg-gray-50/50">
                <CardTitle className="text-gray-900 text-lg">SEO & Social Metadata</CardTitle>
              </CardHeader>
              <CardContent className="space-y-4 pt-6">
                <FormField
                  control={form.control}
                  name="metaTitle"
                  render={({ field }) => (
                    <FormItem>
                      <FormLabel className="text-gray-700">Meta Title</FormLabel>
                      <FormControl>
                        <Input {...field} placeholder="Optimised title for search results" />
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />
                <FormField
                  control={form.control}
                  name="metaDescription"
                  render={({ field }) => (
                    <FormItem>
                      <FormLabel className="text-gray-700">Meta Description</FormLabel>
                      <FormControl>
                        <Textarea {...field} rows={3} placeholder="Engaging summary for search snippets" className="resize-none" />
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />
              </CardContent>
            </Card>
          </div>

          <div className="space-y-6 lg:col-span-1">
            <Card className="border-gray-200 shadow-sm">
              <CardHeader className="border-b border-gray-100 bg-gray-50/50">
                <CardTitle className="text-gray-900 text-lg">Article Configuration</CardTitle>
              </CardHeader>
              <CardContent className="space-y-4 pt-6">
                <FormField
                  control={form.control}
                  name="title"
                  render={({ field }) => (
                    <FormItem>
                      <FormLabel className="text-gray-700">Title</FormLabel>
                      <div className="flex gap-2">
                        <FormControl>
                          <Input
                            placeholder="Post title"
                            {...field}
                          />
                        </FormControl>
                        <Button
                          type="button"
                          variant="outline"
                          size="icon"
                          onClick={generateSlug}
                          className="shrink-0"
                          title="Generate Slug"
                        >
                          <Sparkles size={18} />
                        </Button>
                      </div>
                      <FormMessage />
                    </FormItem>
                  )}
                />
                <FormField
                  control={form.control}
                  name="slug"
                  render={({ field }) => (
                    <FormItem>
                      <FormLabel className="text-gray-700">Slug</FormLabel>
                      <FormControl>
                        <Input
                          placeholder="url-slug-here"
                          {...field}
                          className="font-mono text-sm"
                        />
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />
                <FormField
                  control={form.control}
                  name="publishedAt"
                  render={({ field }) => (
                    <FormItem>
                      <FormLabel className="text-gray-700">Publish Date</FormLabel>
                      <FormControl>
                        <Input type="date" {...field} />
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />
                
                <div className="space-y-2 pt-2">
                  <FormLabel className="text-gray-700">Featured Image</FormLabel>
                  <PexelsImagePicker
                    onSelect={(url) => setValue('imageUrl', url, { shouldDirty: true })}
                    currentImageUrl={imageUrl}
                    suggestions={tagsStr.split(',').map(t => t.trim()).filter(Boolean)}
                  />
                  <FormField
                    control={form.control}
                    name="imageUrl"
                    render={({ field }) => (
                      <FormItem>
                        <FormControl>
                          <Input placeholder="Direct Image URL" {...field} className="text-xs font-mono" />
                        </FormControl>
                        <FormMessage />
                      </FormItem>
                    )}
                  />
                </div>

                <FormField
                  control={form.control}
                  name="excerpt"
                  render={({ field }) => (
                    <FormItem>
                      <FormLabel className="text-gray-700">Excerpt</FormLabel>
                      <FormControl>
                        <Textarea {...field} rows={3} placeholder="Short teaser for the post grid" className="resize-none text-sm" />
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />
                <FormField
                  control={form.control}
                  name="tags"
                  render={({ field }) => (
                    <FormItem>
                      <FormLabel className="text-gray-700">Tags</FormLabel>
                      <FormControl>
                        <Input placeholder="tag1, tag2, tag3" {...field} />
                      </FormControl>
                      <FormDescription>Comma-separated list</FormDescription>
                      <FormMessage />
                    </FormItem>
                  )}
                />
                <FormField
                  control={form.control}
                  name="keywords"
                  render={({ field }) => (
                    <FormItem>
                      <FormLabel className="text-gray-700">Keywords</FormLabel>
                      <FormControl>
                        <Input placeholder="SEO keywords; separated by; semicolon" {...field} />
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />
                <FormField
                  control={form.control}
                  name="reading_time_minutes"
                  render={({ field }) => (
                    <FormItem>
                      <FormLabel className="text-gray-700">Reading Time (min)</FormLabel>
                      <FormControl>
                        <Input 
                          type="number" 
                          {...field} 
                          onChange={(e) => field.onChange(parseInt(e.target.value) || 0)}
                        />
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />
                <FormField
                  control={form.control}
                  name="status"
                  render={({ field }) => (
                    <FormItem>
                      <FormLabel className="text-gray-700">Status</FormLabel>
                      <FormControl>
                        <select
                          {...field}
                          className="w-full rounded-md border border-gray-200 bg-white px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-emerald-500"
                        >
                          <option value="published">Published</option>
                          <option value="draft">Draft</option>
                        </select>
                      </FormControl>
                      <FormMessage />
                    </FormItem>
                  )}
                />
              </CardContent>
            </Card>
          </div>
        </div>

        <div className="flex items-center justify-end gap-4 sticky bottom-8 bg-white/90 backdrop-blur-md p-6 rounded-2xl border border-gray-200 shadow-xl z-20">
          <Button type="button" variant="ghost" asChild className="text-gray-500 hover:text-gray-900">
            <Link href="/blog">
              <X className="mr-2 h-4 w-4" /> Cancel
            </Link>
          </Button>
          <Button type="submit" disabled={isPending} className="min-w-[160px] shadow-lg shadow-emerald-600/20">
            {isPending ? (
              <Loader2 className="mr-2 h-4 w-4 animate-spin" />
            ) : (
              <Save className="mr-2 h-4 w-4" />
            )}
            {isEditing ? 'Save Changes' : 'Create Article'}
          </Button>
        </div>
      </form>
    </Form>
  );
}
</file>

<file path="admin/app/messages/page.tsx">
"use client";

import { useState, useEffect } from "react";
import { getMessages, deleteMessage, updateMessage } from "@/lib/db";
import type { ContactMessage } from "@/lib/types";
import Link from "next/link";
import { Eye, Trash2, CheckCircle } from "lucide-react";
import ConfirmDialog from "@/components/ConfirmDialog";

function fmt(iso: string) {
  if (!iso) return "—";
  return new Date(iso).toLocaleDateString("en-ZA", {
    day: "numeric", month: "short", year: "numeric",
    hour: "2-digit", minute: "2-digit",
  });
}

export default function MessagesPage() {
  const [messages, setMessages] = useState<ContactMessage[]>([]);
  const [loading, setLoading] = useState(true);
  const [deleteId, setDeleteId] = useState<string | null>(null);
  const [deleting, setDeleting] = useState(false);

  useEffect(() => {
    const fetchMessages = async () => {
      try {
        const data = await getMessages();
        setMessages(data);
      } catch (error) {
        console.error("Failed to load messages:", error);
      } finally {
        setLoading(false);
      }
    };
    fetchMessages();
  }, []);

  const handleDelete = async () => {
    if (!deleteId) return;
    setDeleting(true);
    try {
      await deleteMessage(deleteId);
      setMessages((prev) => prev.filter((m) => m.id !== deleteId));
      setDeleteId(null);
    } catch (error) {
      console.error("Failed to delete message:", error);
    } finally {
      setDeleting(false);
    }
  };

  const handleMarkResponded = async (id: string, responded: boolean) => {
    try {
      await updateMessage(id, { responded: !responded });
      setMessages((prev) =>
        prev.map((m) => (m.id === id ? { ...m, responded: !responded } : m))
      );
    } catch (error) {
      console.error("Failed to update message:", error);
    }
  };

  if (loading) {
    return (
      <div className="flex items-center justify-center py-20">
        <p className="text-gray-400">Loading messages...</p>
      </div>
    );
  }

  return (
    <div>
      <h1 className="text-2xl font-bold text-gray-900 mb-1">Messages</h1>
      <p className="text-gray-500 text-sm mb-8">
        {messages.length} message{messages.length !== 1 ? "s" : ""} received
      </p>

      {messages.length === 0 ? (
        <div className="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
          <p className="text-sm text-gray-400">No messages yet.</p>
        </div>
      ) : (
        <div className="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
          <table className="w-full text-sm">
            <thead className="bg-gray-50 border-b border-gray-200">
              <tr>
                <th className="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Name</th>
                <th className="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Email</th>
                <th className="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Received</th>
                <th className="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Status</th>
                <th className="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Actions</th>
              </tr>
            </thead>
            <tbody className="divide-y divide-gray-100">
              {messages.map((m) => (
                <tr
                  key={m.id}
                  className={`hover:bg-gray-50 transition-colors ${!m.read ? "bg-blue-50" : ""}`}
                >
                  <td className="px-5 py-3">
                    <p className="font-medium text-gray-900">{m.name}</p>
                  </td>
                  <td className="px-5 py-3">
                    <a href={`mailto:${m.email}`} className="text-emerald-600 hover:underline break-all">
                      {m.email}
                    </a>
                  </td>
                  <td className="px-5 py-3 text-gray-600">{fmt(m.createdAt)}</td>
                  <td className="px-5 py-3">
                    {m.responded ? (
                      <span className="inline-flex items-center gap-1 bg-emerald-50 text-emerald-700 px-2 py-1 rounded text-xs font-medium">
                        <CheckCircle size={14} />
                        Responded
                      </span>
                    ) : (
                      <span className="inline-flex items-center gap-1 bg-yellow-50 text-yellow-700 px-2 py-1 rounded text-xs font-medium">
                        Pending
                      </span>
                    )}
                  </td>
                  <td className="px-5 py-3">
                    <div className="flex items-center gap-2">
                      <Link
                        href={`/messages/${m.id}`}
                        className="inline-flex items-center gap-1 text-emerald-600 hover:text-emerald-700 p-1 rounded"
                        title="View message"
                      >
                        <Eye size={16} />
                        <span className="sr-only">View</span>
                      </Link>
                      <button
                        onClick={() => handleMarkResponded(m.id, m.responded ?? false)}
                        className={`inline-flex items-center gap-1 p-1 rounded ${
                          m.responded
                            ? "text-gray-400"
                            : "text-blue-600 hover:text-blue-700"
                        }`}
                        title={m.responded ? "Mark as not responded" : "Mark as responded"}
                      >
                        <CheckCircle size={16} />
                        <span className="sr-only">{m.responded ? "Not responded" : "Responded"}</span>
                      </button>
                      <button
                        onClick={() => setDeleteId(m.id)}
                        className="inline-flex items-center gap-1 text-red-600 hover:text-red-700 p-1 rounded"
                        title="Delete message"
                      >
                        <Trash2 size={16} />
                        <span className="sr-only">Delete</span>
                      </button>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

      <ConfirmDialog
        isOpen={deleteId !== null}
        title="Delete Message"
        message="Are you sure you want to delete this message? This action cannot be undone."
        onConfirm={handleDelete}
        onCancel={() => setDeleteId(null)}
        isLoading={deleting}
      />
    </div>
  );
}
</file>

<file path="admin/app/services/page.tsx">
"use client";

import { useEffect, useState } from "react";
import { getServices, deleteService, updateService, createService } from "@/lib/db";
import type { ServiceDoc } from "@/lib/types";
import Link from "next/link";
import { Edit, Trash2, Plus, ToggleRight, ToggleLeft } from "lucide-react";
import ConfirmDialog from "@/components/ConfirmDialog";

const SEED_PACKAGES = [
  { title: "Landing Page", price: "R1,000", category: "Website Design", description: "A focused single-page website to convert visitors for a specific campaign or goal.", active: true },
  { title: "Base Package", price: "R1,500", category: "Website Design", description: "A professional 5-page website, perfect for a strong and comprehensive online presence.", active: true },
  { title: "Standard Package", price: "R2,500", category: "Website Design", description: "A complete, custom-designed online presence with advanced features.", active: true },
  { title: "E-commerce Package", price: "From R5,000", category: "Website Design", description: "A fully functional online store to sell your products.", active: true },
  { title: "Local Visibility Starter", price: "R2,000", category: "Website Design", description: "The Base Package plus all the tools needed to rank locally.", active: true },
  { title: ".co.za Domain", price: "R200/year", category: "Domain Registration", description: "A trusted South African domain with full ownership transfer and DNS setup.", active: true },
  { title: ".com Domain", price: "R250/year", category: "Domain Registration", description: "The globally recognised domain extension with full ownership transfer.", active: true },
  { title: "Domain + Full Setup", price: "R500 once-off", category: "Domain Registration", description: "Domain registration plus complete DNS, email forwarding, and handover.", active: true },
  { title: "Starter Email", price: "R99/month", category: "Email Hosting", description: "One professional business email address for a sole trader or small business.", active: true },
  { title: "Business Email", price: "R199/month", category: "Email Hosting", description: "Up to 5 professional mailboxes for your growing team.", active: true },
  { title: "Enterprise Email", price: "R399/month", category: "Email Hosting", description: "Unlimited mailboxes, 25 GB per box, archiving, and priority support.", active: true },
  { title: "Flyer / Poster", price: "R300", category: "Graphic Design", description: "A professionally designed A5 or A4 flyer or poster for print or digital.", active: true },
  { title: "Business Card Set", price: "R500", category: "Graphic Design", description: "A professional double-sided business card design — print-ready.", active: true },
  { title: "Social Media Kit", price: "R800", category: "Graphic Design", description: "A full set of branded social media assets — profile, cover, and 5 post templates.", active: true },
  { title: "Full Brand Identity", price: "R1,500", category: "Graphic Design", description: "Logo, colour palette, typography, and stationery — everything to launch a brand.", active: true },
];

const CATEGORY_COLORS: Record<string, string> = {
  "Website Design": "bg-green-100 text-green-800",
  "Domain Registration": "bg-blue-100 text-blue-800",
  "Email Hosting": "bg-purple-100 text-purple-800",
  "Graphic Design": "bg-orange-100 text-orange-800",
};

export default function ServicesPage() {
  const [services, setServices] = useState<ServiceDoc[]>([]);
  const [loading, setLoading] = useState(true);
  const [seeding, setSeeding] = useState(false);
  const [seedDone, setSeedDone] = useState(false);
  const [error, setError] = useState<string | null>(null);
  const [deleteId, setDeleteId] = useState<string | null>(null);
  const [deleting, setDeleting] = useState(false);

  const fetchServices = async () => {
    setLoading(true);
    setError(null);
    try {
      const data = await getServices();
      setServices(data);
    } catch (e: any) {
      setError(e.message ?? "Failed to load services.");
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => {
    fetchServices();
  }, []);

  const handleSeed = async () => {
    if (!confirm(`This will add ${SEED_PACKAGES.length} packages to Firestore. Continue?`)) return;
    setSeeding(true);
    setError(null);
    try {
      for (const pkg of SEED_PACKAGES) {
        await createService(pkg);
      }
      setSeedDone(true);
      await fetchServices();
    } catch (e: any) {
      setError(e.message ?? "Seed failed.");
    } finally {
      setSeeding(false);
    }
  };

  const handleToggleActive = async (id: string, current: boolean) => {
    try {
      await updateService(id, { active: !current });
      setServices((prev) =>
        prev.map((s) => (s.id === id ? { ...s, active: !current } : s))
      );
    } catch (e: any) {
      setError(e.message);
    }
  };

  const handleDelete = async () => {
    if (!deleteId) return;
    setDeleting(true);
    try {
      await deleteService(deleteId);
      setServices((prev) => prev.filter((s) => s.id !== deleteId));
      setDeleteId(null);
    } catch (e: any) {
      setError(e.message);
    } finally {
      setDeleting(false);
    }
  };

  const grouped = services.reduce<Record<string, ServiceDoc[]>>((acc, s) => {
    const cat = s.category || "Uncategorised";
    if (!acc[cat]) acc[cat] = [];
    acc[cat].push(s);
    return acc;
  }, {});

  return (
    <div>
      <div className="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-8">
        <div>
          <h1 className="text-2xl font-bold text-gray-900">Services</h1>
          <p className="text-gray-500 text-sm mt-1">Manage your service packages across all categories.</p>
        </div>
        <div className="flex gap-3 flex-wrap">
          <Link
            href="/services/create"
            className="inline-flex items-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-2 px-4 rounded-lg text-sm transition-colors"
          >
            <Plus size={16} />
            New Service
          </Link>
          {services.length === 0 && !loading && (
            <button
              onClick={handleSeed}
              disabled={seeding || seedDone}
              className="inline-flex items-center gap-2 bg-blue-600 hover:bg-blue-700 disabled:opacity-50 text-white font-semibold py-2 px-4 rounded-lg text-sm transition-colors"
            >
              {seeding ? "Seeding…" : seedDone ? "Done ✓" : `Seed ${SEED_PACKAGES.length} Packages`}
            </button>
          )}
          <button
            onClick={fetchServices}
            className="inline-flex items-center gap-2 bg-white border border-gray-200 hover:bg-gray-50 text-gray-700 font-semibold py-2 px-4 rounded-lg text-sm transition-colors"
          >
            Refresh
          </button>
        </div>
      </div>

      {error && (
        <div className="bg-red-50 border border-red-200 rounded-lg p-4 mb-6 text-sm text-red-700">
          {error}
        </div>
      )}

      {loading ? (
        <div className="text-center py-20 text-gray-400 text-sm">Loading services…</div>
      ) : services.length === 0 ? (
        <div className="bg-white rounded-xl border border-gray-200 p-10 text-center shadow-sm">
          <p className="text-gray-700 font-semibold mb-1">No services in Firebase yet.</p>
          <p className="text-gray-400 text-sm mb-4">
            Click <strong>Seed Packages</strong> to push your full catalogue or{" "}
            <strong>New Service</strong> to create one manually.
          </p>
          <div className="flex gap-3 justify-center">
            <Link
              href="/services/create"
              className="inline-flex items-center gap-2 bg-emerald-600 hover:bg-emerald-700 text-white font-semibold py-2 px-4 rounded-lg text-sm"
