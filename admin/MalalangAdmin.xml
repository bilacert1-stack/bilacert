              ) : comments.length === 0 ? (
                <div className="p-12 text-center text-gray-400 italic">No comments on this article yet.</div>
              ) : (
                <div className="divide-y divide-gray-100">
                  {comments.map((comment) => (
                    <div key={comment.id} className="p-6 hover:bg-gray-50 transition-colors group">
