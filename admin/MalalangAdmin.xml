<file path="admin/lib/validation.ts">
import { z } from "zod";

export const blogPostSchema = z.object({
  title: z.string().min(1, "Title is required"),
  slug: z.string().min(1, "Slug is required").regex(/^[a-z0-9-]+$/, "Invalid slug format"),
  htmlContent: z.string()
    .min(1, "HTML content is required")
    .refine(
      (val) => {
        const h2Count = (val.match(/<h2/g) || []).length;
        return h2Count >= 3 && h2Count <= 6;
      },
      { message: "Content must have between 3 and 6 H2 sections" }
    ),
  excerpt: z.string().max(160, "Excerpt must be max 160 characters").min(1, "Excerpt is required"),
  metaTitle: z.string().min(1, "Meta title is required"),
  metaDescription: z.string()
    .min(150, "Meta description should be at least 150 characters")
    .max(160, "Meta description must be max 160 characters"),
  publishedAt: z.string().refine((val) => !isNaN(Date.parse(val)), {
    message: "Invalid date format",
  }),
  tags: z.array(z.string()).min(1, "At least one tag is required"),
  imageUrl: z.string().min(1, "Image URL is required"),
  reading_time_minutes: z.number().int().min(1, "Reading time must be at least 1 minute"),
  keywords: z.string().min(1, "Keywords are required"),
  source: z.literal("malalang"),
  status: z.enum(["published", "draft"]),
  author: z.object({
    id: z.string(),
    name: z.literal("AEN Nyathi"),
    avatarUrl: z.string(),
    imageUrl: z.string(),
    bio: z.string(),
  }),
});

export type BlogPostInput = z.infer<typeof blogPostSchema>;
