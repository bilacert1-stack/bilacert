<file path="admin/lib/db.ts">
import {
  collection,
  getDocs,
  orderBy,
  query,
  where,
  limit,
  Timestamp,
  addDoc,
  updateDoc,
  deleteDoc,
  doc,
  getDoc,
  serverTimestamp,
} from "firebase/firestore";
import { db } from "./firebase";
import type { BlogPost, Client, ContactMessage, ServiceDoc, BlogComment } from "./types";

function toDate(value: any): string {
  if (!value) return "";
  if (value instanceof Timestamp) return value.toDate().toISOString();
  if (value?.seconds) return new Date(value.seconds * 1000).toISOString();
  return String(value);
}

export async function getBlogs(): Promise<BlogPost[]> {
  try {
    const q = query(collection(db, "blogs"), orderBy("publishedAt", "desc"));
    const snap = await getDocs(q);
    return snap.docs.map((doc) => {
      const d = doc.data();
      return {
        id: doc.id,
        title: d.title ?? "",
        slug: d.slug ?? "",
        htmlContent: d.htmlContent ?? "",
        excerpt: d.excerpt ?? "",
        metaTitle: d.metaTitle ?? "",
        metaDescription: d.metaDescription ?? "",
        publishedAt: toDate(d.publishedAt),
        tags: d.tags ?? [],
        imageUrl: d.imageUrl ?? "",
        reading_time_minutes: d.reading_time_minutes ?? 0,
        keywords: d.keywords ?? "",
        source: d.source ?? "malalang",
        status: d.status ?? "published",
        author: d.author ?? {
          id: "abram-ntsako",
          name: "AEN Nyathi",
          avatarUrl: "/assets/profile.jpg",
          imageUrl: "/assets/profile.jpg",
          bio: "Abram Ntsako is the founder of Malalang Pty Ltd, a web development studio dedicated to empowering local businesses in Phalaborwa. With a passion for clean code and user-centric design, he helps SMEs build a strong online presence without breaking the bank."
        },
      } as BlogPost;
    });
  } catch (error) {
    console.error("Error fetching blogs:", error);
    return [];
  }
}

export async function getClients(): Promise<Client[]> {
  try {
    const snap = await getDocs(collection(db, "clients"));
    return snap.docs.map((doc) => {
      const d = doc.data();
      return {
        id: doc.id,
        userName: d.userName ?? d.fullName ?? "",
        fullName: d.fullName ?? d.userName ?? "",
        businessName: d.businessName ?? "",
        email: d.email ?? "",
        phone: d.phone ?? doc.id,
        bookings: d.bookings ?? [],
        createdAt: toDate(d.createdAt),
        updatedAt: toDate(d.updatedAt),
        meetingType: d.meetingType ?? "",
        preferredDate: d.preferredDate ?? "",
        preferredTime: d.preferredTime ?? "",
      } as Client;
    });
  } catch {
    return [];
  }
}

export async function getMessages(count = 50): Promise<ContactMessage[]> {
  try {
    const q = query(
      collection(db, "contacts"),
      orderBy("createdAt", "desc"),
      limit(count)
    );
    const snap = await getDocs(q);
    return snap.docs.map((doc) => {
      const d = doc.data();
      return {
        id: doc.id,
        name: d.name ?? "",
        email: d.email ?? "",
        message: d.message ?? "",
        createdAt: toDate(d.createdAt),
      } as ContactMessage;
    });
  } catch {
    return [];
  }
}

export async function getDashboardStats() {
  const [blogs, clients, messages] = await Promise.all([
    getBlogs(),
    getClients(),
    getMessages(),
  ]);

  const allBookings = clients.flatMap((c) =>
    (c.bookings ?? []).map((b) => ({
      ...b,
      clientName: c.userName || c.fullName || c.phone,
      submittedAt: toDate(b.submittedAt),
    }))
  );

  return { blogs, clients, messages, allBookings };
}

// ============ BLOG CRUD ============

export async function getBlogById(id: string): Promise<BlogPost | null> {
  try {
    const snap = await getDoc(doc(db, "blogs", id));
    if (!snap.exists()) return null;
    const d = snap.data();
    return {
      id: snap.id,
      title: d.title ?? "",
      slug: d.slug ?? "",
      htmlContent: d.htmlContent ?? "",
      excerpt: d.excerpt ?? "",
      metaTitle: d.metaTitle ?? "",
      metaDescription: d.metaDescription ?? "",
      publishedAt: toDate(d.publishedAt),
      tags: d.tags ?? [],
      imageUrl: d.imageUrl ?? "",
      reading_time_minutes: d.reading_time_minutes ?? 0,
      keywords: d.keywords ?? "",
      source: d.source ?? "malalang",
      status: d.status ?? "published",
      author: d.author ?? {
        id: "abram-ntsako",
        name: "AEN Nyathi",
        avatarUrl: "/assets/profile.jpg",
        imageUrl: "/assets/profile.jpg",
        bio: "Abram Ntsako is the founder of Malalang Pty Ltd, a web development studio dedicated to empowering local businesses in Phalaborwa. With a passion for clean code and user-centric design, he helps SMEs build a strong online presence without breaking the bank."
      },
    } as BlogPost;
  } catch (error) {
    console.error("Error fetching blog by id:", error);
    return null;
  }
}

export async function createBlog(data: Omit<BlogPost, "id">): Promise<string> {
  try {
    const ref = await addDoc(collection(db, "blogs"), {
      ...data,
      publishedAt: new Date(data.publishedAt),
      createdAt: serverTimestamp(),
    });
    return ref.id;
  } catch (e) {
    throw new Error(`Failed to create blog: ${e}`);
  }
}

export async function updateBlog(id: string, data: Partial<BlogPost>): Promise<void> {
  try {
    const updateData: any = { ...data };
    if (data.publishedAt) {
      updateData.publishedAt = new Date(data.publishedAt);
    }
    updateData.updatedAt = serverTimestamp();
    
    await updateDoc(doc(db, "blogs", id), updateData);
  } catch (e) {
    throw new Error(`Failed to update blog: ${e}`);
  }
}

export async function deleteBlog(id: string): Promise<void> {
  try {
    await deleteDoc(doc(db, "blogs", id));
  } catch (e) {
    throw new Error(`Failed to delete blog: ${e}`);
  }
}

// ============ MESSAGE CRUD ============

export async function getMessageById(id: string): Promise<ContactMessage | null> {
  try {
    const snap = await getDoc(doc(db, "contacts", id));
    if (!snap.exists()) return null;
    const d = snap.data();
    return {
      id: snap.id,
      name: d.name ?? "",
      email: d.email ?? "",
      message: d.message ?? "",
      createdAt: toDate(d.createdAt),
      read: d.read ?? false,
      responded: d.responded ?? false,
    } as ContactMessage;
  } catch {
    return null;
  }
}

export async function updateMessage(id: string, data: Partial<ContactMessage>): Promise<void> {
  try {
    await updateDoc(doc(db, "contacts", id), {
      ...(data.read !== undefined && { read: data.read }),
      ...(data.responded !== undefined && { responded: data.responded }),
      updatedAt: serverTimestamp(),
    });
  } catch (e) {
    throw new Error(`Failed to update message: ${e}`);
  }
}

export async function deleteMessage(id: string): Promise<void> {
  try {
    await deleteDoc(doc(db, "contacts", id));
  } catch (e) {
    throw new Error(`Failed to delete message: ${e}`);
  }
}

// ============ SERVICE CRUD ============

export async function getServiceById(id: string): Promise<ServiceDoc | null> {
  try {
    const snap = await getDoc(doc(db, "services", id));
    if (!snap.exists()) return null;
    const d = snap.data();
    return {
      id: snap.id,
      title: d.title ?? "",
      price: d.price ?? "",
      category: d.category ?? "",
      description: d.description ?? "",
      active: d.active ?? true,
    } as ServiceDoc;
  } catch {
    return null;
  }
}

export async function getServices(): Promise<ServiceDoc[]> {
  try {
    const snap = await getDocs(collection(db, "services"));
    return snap.docs.map((d) => ({
      id: d.id,
      title: d.data().title ?? "",
      price: d.data().price ?? "",
      category: d.data().category ?? "",
      description: d.data().description ?? "",
      active: d.data().active ?? true,
    })) as ServiceDoc[];
  } catch {
    return [];
  }
}

export async function createService(data: Omit<ServiceDoc, "id">): Promise<string> {
  try {
    const ref = await addDoc(collection(db, "services"), {
      title: data.title,
      price: data.price,
      category: data.category,
      description: data.description,
      active: data.active ?? true,
      createdAt: serverTimestamp(),
    });
    return ref.id;
  } catch (e) {
    throw new Error(`Failed to create service: ${e}`);
  }
}

export async function updateService(id: string, data: Partial<ServiceDoc>): Promise<void> {
  try {
    await updateDoc(doc(db, "services", id), {
      ...(data.title && { title: data.title }),
      ...(data.price && { price: data.price }),
      ...(data.category && { category: data.category }),
      ...(data.description !== undefined && { description: data.description }),
      ...(data.active !== undefined && { active: data.active }),
      updatedAt: serverTimestamp(),
    });
  } catch (e) {
    throw new Error(`Failed to update service: ${e}`);
  }
}

export async function deleteService(id: string): Promise<void> {
  try {
    await deleteDoc(doc(db, "services", id));
  } catch (e) {
    throw new Error(`Failed to delete service: ${e}`);
  }
}

// ============ BOOKING CRUD ============

export async function getBookingById(clientId: string, bookingId: string): Promise<any | null> {
  try {
    const snap = await getDoc(doc(db, "clients", clientId));
    if (!snap.exists()) return null;
    const bookings = snap.data().bookings ?? [];
    return bookings.find((b: any) => b.bookingId === bookingId) ?? null;
  } catch {
    return null;
  }
}

export async function updateBooking(clientId: string, bookingId: string, data: any): Promise<void> {
  try {
    const snap = await getDoc(doc(db, "clients", clientId));
    if (!snap.exists()) throw new Error("Client not found");
    const bookings = snap.data().bookings ?? [];
    const updated = bookings.map((b: any) =>
      b.bookingId === bookingId ? { ...b, ...data } : b
    );
    await updateDoc(doc(db, "clients", clientId), {
      bookings: updated,
      updatedAt: serverTimestamp(),
    });
  } catch (e) {
    throw new Error(`Failed to update booking: ${e}`);
  }
}

export async function deleteBooking(clientId: string, bookingId: string): Promise<void> {
  try {
    const snap = await getDoc(doc(db, "clients", clientId));
    if (!snap.exists()) throw new Error("Client not found");
    const bookings = snap.data().bookings ?? [];
    const filtered = bookings.filter((b: any) => b.bookingId !== bookingId);
    await updateDoc(doc(db, "clients", clientId), {
      bookings: filtered,
      updatedAt: serverTimestamp(),
    });
  } catch (e) {
    throw new Error(`Failed to delete booking: ${e}`);
  }
}

// ============ COMMENT CRUD ============

export async function getComments(): Promise<BlogComment[]> {
  try {
    const q = query(collection(db, "comments"), orderBy("createdAt", "desc"));
    const snap = await getDocs(q);
    return snap.docs.map((doc) => {
      const d = doc.data();
      return {
        id: doc.id,
        blogSlug: d.blogSlug ?? "",
        userName: d.userName ?? "",
        email: d.email ?? "",
        phone: d.phone ?? "",
        content: d.content ?? "",
        createdAt: toDate(d.createdAt),
      } as BlogComment;
    });
  } catch {
    return [];
  }
}

export async function getCommentsBySlug(slug: string): Promise<BlogComment[]> {
  try {
    const q = query(
      collection(db, "comments"),
      where("blogSlug", "==", slug),
      orderBy("createdAt", "desc")
    );
    const snap = await getDocs(q);
    return snap.docs.map((doc) => {
      const d = doc.data();
      return {
        id: doc.id,
        blogSlug: d.blogSlug ?? "",
        userName: d.userName ?? "",
        email: d.email ?? "",
        phone: d.phone ?? "",
        content: d.content ?? "",
        createdAt: toDate(d.createdAt),
      } as BlogComment;
    });
  } catch (error) {
    console.error("Error fetching comments by slug:", error);
    return [];
  }
}

export async function deleteComment(id: string): Promise<void> {
  try {
    await deleteDoc(doc(db, "comments", id));
  } catch (e) {
    throw new Error(`Failed to delete comment: ${e}`);
  }
}
