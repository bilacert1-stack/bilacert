"use client";

import { useState, useEffect } from "react";
import { getClients, deleteBooking } from "@/lib/db";
import type { Client, ClientBooking } from "@/lib/types";
import Link from "next/link";
import { Eye, Trash2 } from "lucide-react";
import ConfirmDialog from "@/components/ConfirmDialog";

interface BookingWithClient extends ClientBooking {
  clientName: string;
  clientId: string;
  email?: string;
  phone: string;
  meetingType?: string;
  preferredDate?: string;
  preferredTime?: string;
  submittedAt: string;
}

function fmt(iso: string) {
  if (!iso) return "—";
  return new Date(iso).toLocaleDateString("en-ZA", {
    day: "numeric", month: "short", year: "numeric",
  });
}

function fmtTime(time: string) {
  if (!time) return "";
  return ` at ${time}`;
}

export default function BookingsPage() {
  const [bookings, setBookings] = useState<BookingWithClient[]>([]);
  const [loading, setLoading] = useState(true);
  const [deleteInfo, setDeleteInfo] = useState<{ clientId: string; bookingId: string } | null>(null);
  const [deleting, setDeleting] = useState(false);

  useEffect(() => {
    const fetchBookings = async () => {
      try {
        const clients = await getClients();
        const allBookings = clients
          .flatMap((c) =>
            (c.bookings ?? []).map((b) => ({
              ...b,
              clientName: c.userName || c.fullName || c.phone,
              clientId: c.id,
              email: c.email,
              phone: c.phone,
              meetingType: c.meetingType,
              preferredDate: c.preferredDate,
              preferredTime: c.preferredTime,
              submittedAt: typeof b.submittedAt === "string"
                ? b.submittedAt
                : b.submittedAt?.seconds
                  ? new Date(b.submittedAt.seconds * 1000).toISOString()
                  : "",
            }))
          )
          .sort((a, b) => (b.submittedAt > a.submittedAt ? 1 : -1));
        setBookings(allBookings);
      } catch (error) {
        console.error("Failed to load bookings:", error);
      } finally {
        setLoading(false);
      }
    };
    fetchBookings();
  }, []);

  const handleDelete = async () => {
    if (!deleteInfo) return;
    setDeleting(true);
    try {
      await deleteBooking(deleteInfo.clientId, deleteInfo.bookingId);
      setBookings((prev) =>
        prev.filter((b) =>
          !(b.clientId === deleteInfo.clientId && (b.bookingId || "") === deleteInfo.bookingId)
        )
      );
      setDeleteInfo(null);
    } catch (error) {
      console.error("Failed to delete booking:", error);
    } finally {
      setDeleting(false);
    }
  };

  if (loading) {
    return (
      <div className="flex items-center justify-center py-20">
        <p className="text-gray-400">Loading bookings...</p>
      </div>
    );
  }

  return (
    <div>
      <h1 className="text-2xl font-bold text-gray-900 mb-1">Bookings</h1>
      <p className="text-gray-500 text-sm mb-8">
        {bookings.length} booking{bookings.length !== 1 ? "s" : ""} total
      </p>

      {bookings.length === 0 ? (
        <div className="bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
          <p className="text-sm text-gray-400">No bookings yet.</p>
        </div>
      ) : (
        <div className="bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden">
          <table className="w-full text-sm">
            <thead className="bg-gray-50 border-b border-gray-200">
              <tr>
                <th className="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Client</th>
                <th className="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Service</th>
                <th className="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Meeting</th>
                <th className="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Date</th>
                <th className="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Submitted</th>
                <th className="text-left px-5 py-3 text-xs font-semibold text-gray-500 uppercase tracking-wide">Actions</th>
              </tr>
            </thead>
            <tbody className="divide-y divide-gray-100">
              {bookings.map((b) => (
                <tr key={`${b.clientId}-${b.bookingId}`} className="hover:bg-gray-50 transition-colors">
                  <td className="px-5 py-3">
                    <p className="font-medium text-gray-800">{b.clientName}</p>
                    <p className="text-xs text-gray-400">{b.email || b.phone}</p>
                  </td>
                  <td className="px-5 py-3 text-gray-600">
                    {b.serviceTitle ?? b.servicePackage ?? "—"}
                  </td>
                  <td className="px-5 py-3 text-gray-500">
                    {b.meetingType || "—"}
                  </td>
                  <td className="px-5 py-3 text-gray-500">
                    {b.preferredDate ? `${b.preferredDate}${fmtTime(b.preferredTime ?? "")}` : "—"}
                  </td>
                  <td className="px-5 py-3 text-gray-400">{fmt(b.submittedAt)}</td>
                  <td className="px-5 py-3">
                    <div className="flex items-center gap-2">
                      <Link
                        href={`/bookings/${b.clientId}/${b.bookingId}`}
                        className="inline-flex items-center gap-1 text-emerald-600 hover:text-emerald-700 p-1 rounded"
                        title="View booking details"
                      >
                        <Eye size={16} />
                        <span className="sr-only">View</span>
                      </Link>
                      <button
                        onClick={() => setDeleteInfo({ clientId: b.clientId, bookingId: b.bookingId || "" })}
                        className="inline-flex items-center gap-1 text-red-600 hover:text-red-700 p-1 rounded"
                        title="Delete booking"
                      >
                        <Trash2 size={16} />
                        <span className="sr-only">Delete</span>
                      </button>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}

      <ConfirmDialog
        isOpen={deleteInfo !== null}
        title="Delete Booking"
        message="Are you sure you want to delete this booking? This action cannot be undone."
        onConfirm={handleDelete}
        onCancel={() => setDeleteInfo(null)}
        isLoading={deleting}
      />
    </div>
  );
}
</file>

