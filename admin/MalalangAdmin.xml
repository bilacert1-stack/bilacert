"use client";

import { useState, useEffect } from "react";
import { useRouter, useParams } from "next/navigation";
import { getClients, deleteBooking } from "@/lib/db";
import type { Client, ClientBooking } from "@/lib/types";
import Link from "next/link";
import { ArrowLeft, Trash2 } from "lucide-react";
import ConfirmDialog from "@/components/ConfirmDialog";

export default function BookingDetailPage() {
  const router = useRouter();
  const params = useParams();
  const clientId = params?.clientId as string;
  const bookingId = params?.bookingId as string;

  const [loading, setLoading] = useState(true);
  const [error, setError] = useState<string | null>(null);
  const [client, setClient] = useState<Client | null>(null);
  const [booking, setBooking] = useState<ClientBooking | null>(null);
  const [showDeleteDialog, setShowDeleteDialog] = useState(false);
  const [deleting, setDeleting] = useState(false);

  useEffect(() => {
    const fetchData = async () => {
      try {
        const clients = await getClients();
        const found = clients.find((c) => c.id === clientId);
        if (!found) {
          setError("Client not found");
          return;
        }
        setClient(found);
        const foundBooking = found.bookings.find((b) => b.bookingId === bookingId);
        if (!foundBooking) {
          setError("Booking not found");
          return;
        }
        setBooking(foundBooking);
      } catch (err: any) {
        setError(err.message || "Failed to load booking");
      } finally {
        setLoading(false);
      }
    };
    fetchData();
  }, [clientId, bookingId]);

  const handleDelete = async () => {
    if (!client || !booking) return;
    setDeleting(true);
    try {
      await deleteBooking(client.id, booking.bookingId || "");
      router.push("/bookings");
    } catch (err: any) {
      setError(err.message || "Failed to delete booking");
    } finally {
      setDeleting(false);
    }
  };

  if (loading) {
    return (
      <div className="flex items-center justify-center py-20">
        <p className="text-gray-400">Loading booking details...</p>
      </div>
    );
  }

  if (error || !booking || !client) {
    return (
      <div>
        <Link
          href="/bookings"
          className="inline-flex items-center gap-1 text-emerald-600 hover:text-emerald-700 mb-6"
        >
          <ArrowLeft size={18} />
          Back
        </Link>
        <div className="bg-red-50 border border-red-200 rounded-lg p-6 text-red-700">
          {error || "Booking not found"}
        </div>
      </div>
    );
  }

  const submittedAt = new Date(booking.submittedAt).toLocaleDateString("en-ZA", {
    day: "numeric",
    month: "short",
    year: "numeric",
    hour: "2-digit",
    minute: "2-digit",
  });

  return (
    <div>
      <Link
        href="/bookings"
        className="inline-flex items-center gap-1 text-emerald-600 hover:text-emerald-700 mb-6"
      >
        <ArrowLeft size={18} />
        Back
      </Link>

      <div className="bg-white rounded-xl border border-gray-200 shadow-sm p-8">
        <div className="flex items-start justify-between mb-6">
          <div>
            <h1 className="text-2xl font-bold text-gray-900 mb-1">Booking Details</h1>
            <p className="text-gray-500 text-sm">Submitted {submittedAt}</p>
          </div>
          <button
            onClick={() => setShowDeleteDialog(true)}
            className="inline-flex items-center gap-2 text-red-600 hover:text-red-700 p-2 rounded"
          >
            <Trash2 size={18} />
            Delete
          </button>
        </div>

        <div className="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div>
            <h2 className="text-lg font-semibold text-gray-900 mb-4">Service</h2>
            <div className="space-y-3">
              <div>
                <p className="text-xs text-gray-500 uppercase tracking-wide">Service Title</p>
                <p className="text-gray-900 font-medium">{booking.serviceTitle}</p>
              </div>
              <div>
                <p className="text-xs text-gray-500 uppercase tracking-wide">Package</p>
                <p className="text-gray-900 font-medium">{booking.servicePackage}</p>
              </div>
            </div>
          </div>

          <div>
            <h2 className="text-lg font-semibold text-gray-900 mb-4">Client Information</h2>
            <div className="space-y-3">
              <div>
                <p className="text-xs text-gray-500 uppercase tracking-wide">Client Name</p>
                <p className="text-gray-900 font-medium">{client.fullName || client.userName || client.phone}</p>
              </div>
              <div>
                <p className="text-xs text-gray-500 uppercase tracking-wide">Email</p>
                <p className="text-gray-900 break-all">{client.email || "—"}</p>
              </div>
              <div>
                <p className="text-xs text-gray-500 uppercase tracking-wide">Phone</p>
                <p className="text-gray-900 font-medium">{client.phone}</p>
              </div>
              <div>
                <p className="text-xs text-gray-500 uppercase tracking-wide">Business</p>
                <p className="text-gray-900 font-medium">{client.businessName || "—"}</p>
              </div>
            </div>
          </div>
        </div>

        <div className="mt-8 pt-8 border-t border-gray-200">
          <h2 className="text-lg font-semibold text-gray-900 mb-4">Preferred Meeting Details</h2>
          <div className="grid grid-cols-1 md:grid-cols-3 gap-8">
            <div>
              <p className="text-xs text-gray-500 uppercase tracking-wide">Meeting Type</p>
              <p className="text-gray-900 font-medium">{client.meetingType || "—"}</p>
            </div>
            <div>
              <p className="text-xs text-gray-500 uppercase tracking-wide">Preferred Date</p>
              <p className="text-gray-900 font-medium">{client.preferredDate || "—"}</p>
            </div>
            <div>
              <p className="text-xs text-gray-500 uppercase tracking-wide">Preferred Time</p>
              <p className="text-gray-900 font-medium">{client.preferredTime || "—"}</p>
            </div>
          </div>
        </div>
      </div>

      <ConfirmDialog
        isOpen={showDeleteDialog}
        title="Delete Booking"
        message="Are you sure you want to delete this booking? This action cannot be undone."
        onConfirm={handleDelete}
        onCancel={() => setShowDeleteDialog(false)}
        isLoading={deleting}
      />
    </div>
  );
}
